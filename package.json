{
  "name": "openstax-ai-toolbox",
  "version": "0.1.0",
  "description": "OpenStax AI toolbox — skills + tools served via MCP",
  "bin": {
    "openstax-ai-toolbox-mcp": "./mcp-server.ts"
  },
  "scripts": {
    "start": "tsx mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "sync-skills": "tsx scripts/sync-skills.ts",
    "package-skills": "npm run sync-skills && tsx scripts/package-skills.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
